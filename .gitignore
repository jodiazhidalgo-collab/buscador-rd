# Proyecto unificado Buscador RD: no subir runtime, backups ni credenciales reales.

_backups/
.agents/*
!.agents/skills/
!.agents/skills/**
.codex/
_codex_runtime/
.playwright-mcp/
test-results/
.env
.env.*
!.env.example

# Compose real con credenciales locales. Versionar solo docker-compose.example.yaml.
docker-compose.yaml

# Runtime de BTDigg + RD.
config/btdigg-rd/data/
config/btdigg-rd/git/

# Runtime y credenciales de Cloudflared.
config/cloudflared/data/
config/cloudflared/logs/
config/cloudflared/config/public.env
config/cloudflared/config/secrets.env

# Runtime, modelos y clave local de Whisper.
config/whisper/data/
config/whisper/logs/
config/whisper/config/*.env
config/whisper/config/*secret*
config/whisper/config/*token*
config/whisper/config/*key*

# Residuos dentro de servicios.
services/**/_backups/
services/**/.agents/
services/**/.codex/
services/**/.playwright-mcp/
services/**/_codex_runtime/
services/**/data/
services/**/logs/
services/**/test-results/

# Configuracion sensible historica del motor.
services/**/app/motor/btdigg/rd_token.txt
services/**/app/motor/btdigg/config.json
services/**/app/motor/btdigg/exports/
services/**/app/motor/btdigg/temp/
services/**/app/motor/btdigg/logs/
services/**/app/motor/btdigg/Links qB RD/
services/**/app/motor/btdigg/historial_*.txt
services/**/app/motor/btdigg/EDITOR_*.log

# Python/cache/logs/entregables.
**/__pycache__/
*.pyc
.pytest_cache/
*.log
*.tmp
*.part
*.zip
*.lnk
Thumbs.db

# Capturas de comprobacion local.
*.png
*.jpg
*.jpeg
*.webp

# Espejo publico saneado para ChatGPT/GitHub.
!diagnostics_public/
!diagnostics_public/**
diagnostics_public/**/*.db
diagnostics_public/**/*.sqlite
diagnostics_public/**/*.sqlite3
diagnostics_public/**/*.zip
diagnostics_public/**/*.7z
diagnostics_public/**/*.rar
diagnostics_public/**/*.png
diagnostics_public/**/*.jpg
diagnostics_public/**/*.jpeg
diagnostics_public/**/*.webp
